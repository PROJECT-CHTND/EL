# ============================================
# EL Configuration
# ============================================

# ELライセンスキー（必須）
# お問い合わせから取得してください: https://example.com/el
EL_LICENSE_KEY=your-license-key-here

# ============================================
# LLM Provider Settings
# ============================================

# LLMプロバイダー: openai / azure_openai
LLM_PROVIDER=openai

# LLM APIキー
LLM_API_KEY=sk-your-api-key-here

# 使用するLLMモデル
LLM_MODEL=gpt-4

# Azure OpenAI を使用する場合（上記 LLM_PROVIDER=azure_openai に変更）
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_API_VERSION=2024-02-01
# AZURE_OPENAI_DEPLOYMENT=your-deployment-name

# ============================================
# Database
# ============================================

DB_USER=el
DB_PASSWORD=your-db-password
DB_NAME=el_knowledge

# ============================================
# Ports
# ============================================

API_PORT=8000
FRONTEND_PORT=8080

# ============================================
# Logging
# ============================================

# ログレベル: debug / info / warning / error
LOG_LEVEL=info
